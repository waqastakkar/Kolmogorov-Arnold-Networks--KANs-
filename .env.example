# Copy to .env and edit for local environment.
# Path to the ChEMBL 36 SQLite database (absolute or relative to repo root).
CHEMBL_DB_PATH=./chembl_36.db

# Enable CUDA deterministic mode (0 = off, 1 = on). Used by Stage 6 training.
BRD4KAN_DETERMINISTIC=1

# Optional: override default device (auto|cpu|cuda).
BRD4KAN_DEVICE=auto
